\pre\verb<<<|
Chip
├── TensorCore (×2 on most generations)
│   ├── MXU (×4 on v4/v5p, ×2 on v3)       ← matmul
│   │   └── 128×128 systolic array (256×256 on v6e+)
│   ├── VPU (×1)                              ← elementwise, activations
│   │   └── 8×128 ALU grid = 4096 ALUs (×4 per cell on v5)
│   ├── XLU (×2)                              ← cross-lane reduction/permute
│   ├── Scalar Unit (×1, single-threaded)     ← control flow, DMA dispatch
│   ├── VREGs (64 on v5p, 32 on v4)          ← 8×128 each
│   ├── VMEM (~16-128MB, per-core)
│   └── SMEM (tens to hundreds of KB, per-core)
└── CMEM / VMEM_SHARED (128MB, shared across both TensorCores)
<<<
\pre\verb<<<|
HBM
 │
 ├─── DMA ──────────────────────→ VMEM (per-core, vector scratchpad)
 │                                  │
 │                                  ├──→ VREGs ──→ VPU  (elementwise)
 │                                  │       └──→ MXU  (matmul)
 │                                  │              └──→ Accumulators
 │                                  │                      │
 │                                  └──────────────────────┘
 │                                    (results written back)
 │
 ├─── DMA ──────────────────────→ SMEM (per-core, scalar scratchpad)
 │                                  │
 │                                  └──→ SREGs ──→ Scalar Unit
 │                                                    │
 │                                      (dispatches DMA, computes
 │                                       addresses, control flow)
 │
 └─── (shared) ─────────────────→ CMEM (cross-core, feeds into
                                        either TensorCore's VMEM path)
<<<

\put\transclude/expanded{false}

\section{Setting up TPU VM}{
This is SHOCKINGLY difficult to do. I've ultimately ended up with the following to create / connect / delete a TPU VM:
\pre\verb<<<|
gtpu() {
  gcloud compute tpus tpu-vm create "$TPU_NAME" \
    --project="$PROJECT_ID" \
    --zone="$ZONE" \
    --accelerator-type="$ACCELERATOR_TYPE" \
    --version="$VERSION" \
    --metadata startup-script='#! /bin/bash
      curl -LsSf https://astral.sh/uv/0.10.9/install.sh | sh
      EOF'
}
  
tpustop() {
  gcloud compute tpus tpu-vm stop "$TPU_NAME" \
    --zone="$ZONE"
}

tpustart() {
  gcloud compute tpus tpu-vm start "$TPU_NAME" \
    --zone="$ZONE"
}

sshtpu() {
  gcloud compute tpus tpu-vm ssh "$TPU_NAME" --zone="$ZONE"
}

tpudel() {
  gcloud compute tpus tpu-vm delete "$TPU_NAME" \
    --project="$PROJECT_ID" \
    --zone="$ZONE"
}
<<<
and to move files between the TPU VM and my local machine:
\pre\verb<<<|
tpup() {
  local src="$1"
  gcloud compute tpus tpu-vm scp --recurse "./$src" "${TPU_NAME}:${PROJECT_ID}/$src" --zone="$ZONE"
}

tpudwn() {
  local src="$1"
  gcloud compute tpus tpu-vm scp --recurse "${TPU_NAME}:${PROJECT_ID}/$src" "./$src"  --zone="$ZONE"
}

<<<
}


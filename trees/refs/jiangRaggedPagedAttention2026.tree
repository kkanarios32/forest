@misc{jiangRaggedPagedAttention2026,
 title = {Ragged {{Paged Attention}}: {{A High-Performance}} and {{Flexible LLM Inference Kernel}} for {{TPU}}},
 author = {Jiang, Jevin and Chen, Ying and Hechtman, Blake A. and Zhang, Fenghui and Mu, Yarong},
 year = {2026},
 doi = {10.48550/arXiv.2604.15464},
 urldate = {2026-05-04},

 title = {Squeezing {{More}} from the {{Stream}} : {{Learning Representation Online}} for {{Streaming Reinforcement Learning}}},
 author = {Nilaksh and Clavaud, Antoine and Reymond, Mathieu and Rivest, Fran{\c c}ois and Chandar, Sarath},
 year = {2026},
 doi = {10.48550/arXiv.2602.09396},
 urldate = {2026-05-30},

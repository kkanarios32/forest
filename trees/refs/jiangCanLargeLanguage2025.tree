\title{Can Large Language Models Understand Intermediate Representations in Compilers?}
\date{2025-06}
\author/literal{Hailong Jiang}\author/literal{Jianfeng Zhu}\author/literal{Yao Wan}\author/literal{Bo Fang}\author/literal{Hongyu Zhang}\author/literal{Ruoming Jin}\author/literal{Qiang Guan}

\title{Equivalence Checking of ML GPU Kernels}
\date{2025-11}
\author/literal{Kshitij Dubey}\author/literal{Benjamin Driscoll}\author/literal{Anjiang Wei}\author/literal{Neeraj Kayal}\author/literal{Rahul Sharma}\author/literal{Alex Aiken}

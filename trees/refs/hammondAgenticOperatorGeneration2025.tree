\author/literal{Alec M. Hammond}\author/literal{Aram Markosyan}\author/literal{Aman Dontula}\author/literal{Simon Mahns}\author/literal{Zacharias Fisches}\author/literal{Dmitrii Pedchenko}\author/literal{Keyur Muzumdar}\author/literal{Natacha Supper}\author/literal{Mark Saroufim}\author/literal{Joe Isaacson}\author/literal{Laura Wang}\author/literal{Warren Hunt}\author/literal{Kaustubh Gondkar}\author/literal{Roman Levenstein}\author/literal{Gabriel Synnaeve}\author/literal{Richard Li}\author/literal{Jacob Kahn}\author/literal{Ajit Mathews}

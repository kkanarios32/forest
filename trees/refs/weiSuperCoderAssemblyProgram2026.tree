\title{SuperCoder: Assembly Program Superoptimization with Large Language Models}
\date{2026-01}
\author/literal{Anjiang Wei}\author/literal{Tarun Suresh}\author/literal{Huanmi Tan}\author/literal{Yinglun Xu}\author/literal{Gagandeep Singh}\author/literal{Ke Wang}\author/literal{Alex Aiken}

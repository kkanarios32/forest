\title{Towards Robust Agentic CUDA Kernel Benchmarking, Verification, and Optimization}
\date{2025-09}
\author/literal{Robert Tjarko Lange}\author/literal{Qi Sun}\author/literal{Aaditya Prasad}\author/literal{Maxence Faldor}\author/literal{Yujin Tang}\author/literal{David Ha}

\title{AscendKernelGen: A Systematic Study of LLM-Based Kernel Generation for Neural Processing Units}
\date{2026-04}
\author/literal{Xinzi Cao}\author/literal{Jianyang Zhai}\author/literal{Pengfei Li}\author/literal{Zhiheng Hu}\author/literal{Cen Yan}\author/literal{Bingxu Mu}\author/literal{Guanghuan Fang}\author/literal{Bin She}\author/literal{Jiayu Li}\author/literal{Yihan Su}\author/literal{Dongyang Tao}\author/literal{Xiansong Huang}\author/literal{Fan Xu}\author/literal{Feidiao Yang}\author/literal{Yao Lu}\author/literal{Chang-Dong Wang}\author/literal{Yutong Lu}\author/literal{Weicheng Xue}\author/literal{Bin Zhou}\author/literal{Yonghong Tian}

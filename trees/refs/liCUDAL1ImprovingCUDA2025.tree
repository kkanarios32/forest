@misc{liCUDAL1ImprovingCUDA2025,
 title = {{{CUDA-L1}}: {{Improving CUDA Optimization}} via {{Contrastive Reinforcement Learning}}},
 author = {Li, Xiaoya and Sun, Xiaofei and Wang, Albert and Li, Jiwei and Shum, Chris},

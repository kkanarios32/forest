\section{Introduction to JAX AI Stack}{
\p{Three main transformations}
\ul{
  \li{\code{jit()}, \code{grad()}, \code{vmap()}}
  \li{Compile, differentiate, and vectorize}
}
\p{\strong{Distributed training}}
\ol{
    \li{Data parallelism}
    \ul{
    \li{Data sharding: data is split across multiple devices i.e. 32 samples and 8 devices results in 4 unique samples per device.}
    \li{Parameter replication: on each device, we need to replcicate the model parameters to run the forward pass for the unique samples.}
    \li{Gradient aggregation: backward pass we need to perform an \em{all-reduce} to sum and average the gradients across devices. This is automatically done by \code{@nnx.jit}.}
    }
    \li{Tensor parallelism}
    \ul{
      \li{Large weight matrices split across devices. Can train larger models that exceed memory of single device.}
      \li{Devices exchange partial activations to compute layer outputs.}
    }
}
\remark{
\code{nnx.with_partitioning} wraps initialization to bind \code{PartitionSpec} that defines sharding.
}

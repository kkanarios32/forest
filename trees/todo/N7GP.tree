\ul{
  \li{Bus that snoops}
  \li{Valid invalid}
  \li{MSI}
  \li{MESI}
  \li{MOESI}
  \li{Purpose of additional states.}
}
\p{\strong{Design choice:}}
\ul{
  \li{Should cache be shared}
  \li{Should cache be inclusive}
}
\p{\strong{Directory protocol:}}
\ul{
  \li{Why directory over snoop.}
  \li{Broadcasting expensive with lots of cores.}
  \li{Data structure implementation. Broadcast everywhere for overflow.}
  \li{Race conditions.}
}

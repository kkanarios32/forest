import sys
import pandas as pd
import os
import matplotlib.pyplot as plt
import json
from datetime import datetime
from etils import epath
import argparse

import requests
from datetime import timedelta

from dotenv import load_dotenv

import wtheme

env_path = os.path.join(os.path.dirname(os.path.abspath(__file__)), "key.env")
load_dotenv(env_path)
API_KEY = os.environ["WAKA_API"]

DOW = ["Sat", "Sun", "Mon", "Tue", "Wed", "Thu", "Fri"]  # review week ends Friday
TOP_N = 6  # keep the legend legible; the rest collapses into "Other"


def fetch(end_date):
    start_date = end_date - timedelta(days=6)

    end_str = end_date.strftime("%Y-%m-%d")
    start_str = start_date.strftime("%Y-%m-%d")

    # --- API REQUEST ---
    url = "https://wakatime.com/api/v1/users/current/summaries"
    params = {"start": start_str, "end": end_str}

    response = requests.get(url, params=params, auth=(API_KEY, ""))

    if response.status_code != 200:
        print(f"Error: {response.status_code}")
        print(response.text)
        exit(1)

    data = response.json()["data"]

    save_dir = f"data/{end_str}"
    os.makedirs(save_dir, exist_ok=True)
    path = f"{save_dir}/data.json"

    with epath.Path(path).open("w") as fout:
        json.dump(data, fout)

    return data


def long_frame(data, field):
    """Flatten the Wakatime summary into (day, name, hours) rows for a field."""
    records = []
    for entry in data:
        day = datetime.strptime(entry["range"]["date"], "%Y-%m-%d").strftime("%a")
        for item in entry[field]:
            records.append(
                {"day": day, "name": item["name"], "hours": item["total_seconds"] / 3600}
            )
    return pd.DataFrame(records)


def top_n_pivot(df, n=TOP_N, min_hours=0.5):
    """Pivot day x name, keeping the top-n names by total and lumping the rest
    into 'Other'. Returns a (pivot, has_other) pair with columns ordered big→small."""
    df = df[df.groupby("name")["hours"].transform("sum") >= min_hours]
    if df.empty:
        return None, False
    totals = df.groupby("name")["hours"].sum().sort_values(ascending=False)
    keep = list(totals.index[:n])
    has_other = len(totals) > n
    df = df.copy()
    df["name"] = df["name"].where(df["name"].isin(keep), "Other")
    pivot = df.pivot_table(index="day", columns="name", values="hours",
                           aggfunc="sum", fill_value=0).reindex(DOW, fill_value=0)
    cols = [c for c in keep if c in pivot.columns]
    if has_other and "Other" in pivot.columns:
        cols.append("Other")
    return pivot[cols], has_other


def stacked_day_plot(pivot, has_other, ax, title, legend_title):
    n = pivot.shape[1]
    colors = wtheme.palette(n - 1 if has_other else n)
    if has_other:
        colors = colors + [wtheme.OTHER]
    pivot.plot(kind="bar", stacked=True, ax=ax, width=0.74,
               color=colors[:n], edgecolor="white", linewidth=0.7, legend=False)

    # Total hours atop each day's stack.
    totals = pivot.sum(axis=1)
    for x, total in enumerate(totals):
        if total > 0:
            ax.text(x, total + totals.max() * 0.02, f"{total:.1f}",
                    ha="center", va="bottom", fontsize=9, color=wtheme.FAINT)

    ax.set_ylabel("Hours")
    ax.set_xlabel("")
    ax.set_title(title)
    ax.tick_params(axis="x", rotation=0)
    ax.margins(x=0.02)
    ax.set_ylim(0, totals.max() * 1.15 if totals.max() > 0 else 1)
    wtheme.style_axis(ax, grid="y")
    handles, labels = ax.get_legend_handles_labels()
    ax.legend(handles, labels, title=legend_title, loc="upper center",
              bbox_to_anchor=(0.5, -0.12), ncol=min(n, 4))


def plot(data, save_dir):
    lang_pivot, lang_other = top_n_pivot(long_frame(data, "languages"))
    proj_pivot, proj_other = top_n_pivot(long_frame(data, "projects"))

    wtheme.apply()
    fig, axs = plt.subplots(1, 2, figsize=(15, 5.2))

    if lang_pivot is not None:
        stacked_day_plot(lang_pivot, lang_other, axs[0],
                         "By language", "Language")
    if proj_pivot is not None:
        stacked_day_plot(proj_pivot, proj_other, axs[1],
                         "By project", "Project")

    total_hours = sum(e["grand_total"]["total_seconds"] for e in data) / 3600
    wtheme.suptitle(fig, "Coding", f"{total_hours:.1f} hours this week")
    plt.tight_layout(rect=[0, 0, 1, 0.93])

    for a in axs:
        wtheme.round_bars(a, edge="white")
        wtheme.arrows(a)

    os.makedirs(save_dir, exist_ok=True)
    plt.savefig(os.path.join(save_dir, "waka.png"), dpi=200)


def main(argv):
    parser = argparse.ArgumentParser()
    parser.add_argument("dir", help="save directory")

    end_date = datetime.today().date()
    end_str = end_date.strftime("%Y-%m-%d")

    path = f"data/waka/{end_str}.json"
    if os.path.exists(path):
        with epath.Path(path).open("r") as file:
            data = json.load(file)
    else:
        data = fetch(end_date)

    save_dir = argv[0]
    os.makedirs(save_dir, exist_ok=True)
    plot(data, save_dir)


if __name__ == "__main__":
    main(sys.argv[1:])

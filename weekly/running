#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = [
#     "datetime",
#     "fitfile",
#     "garmindb==3.6.4",  # must match the garmindb-cli that builds the DB (schema version skew otherwise)
#     "matplotlib",
#     "numpy",
#     "pandas",
#     "seaborn",
# ]
# ///
# Running

import matplotlib.pyplot as plt
import matplotlib.dates as dates
from datetime import datetime, date, timedelta
import sys
import os

import fitfile
import pandas as pd
from garmindb import GarminConnectConfigManager
from garmindb.garmindb import (
    GarminDb,
    Attributes,
    ActivitiesDb,
    Activities,
)

import wtheme

gc_config = GarminConnectConfigManager()
db_params_dict = gc_config.get_db_params()

garmin_db = GarminDb(db_params_dict)
garmin_act_db = ActivitiesDb(db_params_dict)
measurement_system = Attributes.measurements_type(garmin_db)
unit_strings = fitfile.units.unit_strings[measurement_system]
distance_units = {"miles": "m"}[unit_strings[fitfile.units.UnitTypes.distance_long]]

WEEKS = 16  # how many recent weeks of mileage to show

end_ts = datetime.now()
start_ts = end_ts - timedelta(weeks=WEEKS)

activities = Activities.get_for_period(garmin_act_db, start_ts, end_ts)


def _empty(ax, title, msg="No runs in this period"):
    ax.set_title(title)
    ax.text(0.5, 0.5, msg, ha="center", va="center", color=wtheme.FAINT,
            transform=ax.transAxes)
    ax.set_xticks([])
    ax.set_yticks([])
    for s in ax.spines.values():
        s.set_visible(False)


def weekly_miles(ax):
    # Bucket running distance into weeks (Monday-anchored training weeks).
    runs = []
    for activity in activities:
        if activity.name is None or activity.distance is None or activity.moving_time is None:
            continue
        s = activity.distance
        t = (datetime.combine(date.min, activity.moving_time) - datetime.min).total_seconds() / 60
        if s > 0.5 and 5 < t / s < 15:  # pace/distance heuristic → it's a run
            d = activity.start_time.date()
            week_start = d - timedelta(days=d.weekday())  # Monday of that week
            runs.append((week_start, s))

    if not runs:
        _empty(ax, "Miles per week")
        return 0.0

    df = pd.DataFrame(runs, columns=["week", "miles"])
    weekly = df.groupby("week")["miles"].sum()

    # Continuous weekly index so zero-mileage (rest) weeks stay visible.
    full = pd.date_range(end=end_ts.date() - timedelta(days=end_ts.weekday()),
                         periods=WEEKS, freq="7D")
    weekly = weekly.reindex(full.date, fill_value=0)
    weekly.index = pd.to_datetime(weekly.index)

    roll = weekly.rolling(4, min_periods=1).mean()

    # Trim leading empty weeks so the chart starts where running data begins.
    nonzero = weekly[weekly > 0]
    if not nonzero.empty:
        weekly = weekly.loc[nonzero.index[0]:]
        roll = roll.loc[nonzero.index[0]:]

    ax.bar(weekly.index, weekly.values, width=5.2, color=wtheme.ACCENT,
           zorder=3, label="Weekly miles")
    ax.plot(weekly.index, roll.values, color=wtheme.ACCENT_WARM, linewidth=2.4,
            solid_capstyle="round", zorder=4, label="4-week average")

    # Direct-label each week's mileage.
    ymax = weekly.values.max()
    for x, v in zip(weekly.index, weekly.values):
        if v > 0:
            ax.text(x, v + ymax * 0.02, f"{v:.0f}", ha="center", va="bottom",
                    fontsize=9, color=wtheme.FAINT)

    ax.set_ylabel("Miles")
    ax.set_xlabel("")
    ax.set_ylim(0, ymax * 1.15)
    wtheme.style_axis(ax, grid="y")
    ax.margins(x=0.02)
    ax.xaxis.set_major_locator(dates.WeekdayLocator(byweekday=dates.MO, interval=1))
    ax.xaxis.set_major_formatter(dates.DateFormatter("%b %d"))
    ax.tick_params(axis="x", rotation=0)
    ax.legend(loc="upper left", ncol=2)
    return float(weekly.values.mean())


def main(argv):
    save_dir = argv[0]
    wtheme.apply()
    fig, ax = plt.subplots(figsize=(13, 4.9))
    avg = weekly_miles(ax)
    subtitle = f"{avg:.1f} mi/week average" if avg else None
    wtheme.suptitle(fig, "Running", subtitle)
    plt.tight_layout(rect=[0, 0, 1, 0.93])
    wtheme.round_bars(ax, edge="hue")
    wtheme.arrows(ax)
    os.makedirs(save_dir, exist_ok=True)
    plt.savefig(os.path.join(save_dir, "running.png"), dpi=200)


if __name__ == "__main__":
    main(sys.argv[1:])

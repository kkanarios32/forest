@misc{opryshkoTestTimeGraphSearch2025,
  title = {Test-{{Time Graph Search}} for {{Goal-Conditioned Reinforcement Learning}}},
  author = {Opryshko, Evgenii and Quan, Junwei and Voelcker, Claas and Du, Yilun and Gilitschenski, Igor},
  year = 2025,
  month = oct,
  number = {arXiv:2510.07257},

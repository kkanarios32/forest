@misc{guoRepresentationLearningNonContrastive2025,
  title = {Representation {{Learning}} via {{Non-Contrastive Mutual Information}}},
  author = {Guo, Zhaohan Daniel and Pires, Bernardo Avila and Khetarpal, Khimya and Schuurmans, Dale and Dai, Bo},
  year = 2025,
  month = apr,
  number = {arXiv:2504.16667},
  eprint = {2504.16667},

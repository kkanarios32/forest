@misc{prietoGrokkingEdgeNumerical2025,
  title = {Grokking at the {{Edge}} of {{Numerical Stability}}},
  author = {Prieto, Lucas and Barsbey, Melih and Mediano, Pedro A. M. and Birdal, Tolga},
  year = 2025,
  month = jan,
  number = {arXiv:2501.04697},
  eprint = {2501.04697},
  primaryclass = {cs},

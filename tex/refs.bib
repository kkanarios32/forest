@misc{chane-saneGoalConditionedReinforcementLearning2021,
  title = {Goal-{{Conditioned Reinforcement Learning}} with {{Imagined Subgoals}}},
  author = {{Chane-Sane}, Elliot and Schmid, Cordelia and Laptev, Ivan},
  year = 2021,
  month = jul,

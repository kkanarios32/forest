#!/usr/bin/env python3
import os
import shutil
import subprocess
from http.server import BaseHTTPRequestHandler, HTTPServer
from urllib.parse import urlparse, parse_qs

SOCK = os.environ.get('NVIM_SOCK', '/tmp/nvim-forest.sock')
PORT = int(os.environ.get('FOPEN_PORT', '1235'))
WIN_TITLE = 'forest-fserve'
TMUX_SESSION = 'forest'
TMUX_EDIT_WINDOW = 'edit'


def focus_or_spawn_alacritty():
    rc = subprocess.run(['wmctrl', '-a', WIN_TITLE],
                        capture_output=True).returncode
    if rc != 0:
        subprocess.Popen(
            ['alacritty', '-t', WIN_TITLE, '-e',
             'tmux', 'attach', '-t', TMUX_SESSION],
            start_new_session=True,
        )


class Handler(BaseHTTPRequestHandler):
    def do_GET(self):
        u = urlparse(self.path)
        if u.path == '/open':
            path = parse_qs(u.query).get('path', [''])[0]
            if not path:
                self.send_response(400); self.end_headers(); self.wfile.write(b'missing path'); return
            if not os.path.exists(SOCK):
                self.send_response(503); self.end_headers(); self.wfile.write(b'nvim socket not ready'); return
            subprocess.run(['nvim', '--server', SOCK, '--remote', path],
                           check=False)
            subprocess.run(['tmux', 'select-window', '-t',
                            f'{TMUX_SESSION}:{TMUX_EDIT_WINDOW}'],
                           check=False)
            focus_or_spawn_alacritty()
            self.send_response(200); self.end_headers(); self.wfile.write(b'ok')
            return
        self.send_response(404); self.end_headers()

    def end_headers(self):
        self.send_header('Access-Control-Allow-Origin', '*')
        super().end_headers()

    def log_message(self, *a):
        pass


HTTPServer(('127.0.0.1', PORT), Handler).serve_forever()
